    {
      "name": "POST predict image v2 check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"V2 returns prediction metadata\", function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"predicted_class\");",
              "  pm.expect(json).to.have.property(\"confidence\");",
              "  pm.expect(json).to.have.property(\"execution_time\");",
              "  pm.expect(json.confidence).to.be.a(\"number\");",
              "  pm.expect(json.execution_time).to.be.a(\"number\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
