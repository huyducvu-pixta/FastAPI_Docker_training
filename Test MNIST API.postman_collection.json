    {
      "name": "POST predict image v1 check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"V1 returns predicted_class only\", function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"predicted_class\");",
              "  pm.expect(json).to.not.have.property(\"confidence\");",
              "  pm.expect(json).to.not.have.property(\"execution_time\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"image_path\": \"digit_8.png\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8000/api/predict/v1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8000",
          "path": [
            "api",
